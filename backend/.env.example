# Backend Environment Variables - Development
# For production on Railway, set these in Railway dashboard

# MongoDB Atlas Connection
MONGO_URL=mongodb+srv://username:password@cluster-name.mongodb.net/?retryWrites=true&w=majority
DB_NAME=xac_crm_db

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# CORS - Allow frontend origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# WhatsApp Service (Baileys running on laptop)
WHATSAPP_SERVICE_URL=http://localhost:3001

# Optional: API Keys
# OPENAI_KEY=sk-...
# EMERGENT_LLM_KEY=not-needed-anymore
