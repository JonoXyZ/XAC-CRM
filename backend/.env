# backend/.env - Development Configuration
# For production, set these in your deployment platform (Railway/Render/Heroku)

# Supabase PostgreSQL Database (Primary database)
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:Xyzservices12!!@db.fmztbzqmkywsbimzlivi.supabase.co:5432/postgres"

# MongoDB Atlas (for non-auth data - optional, app will work without it)
# Production: mongodb+srv://username:password@cluster-name.mongodb.net/xac_crm_db
MONGO_URL="mongodb://mongo:27017"
DB_NAME="xac_crm_db"

# Security - Change these in production!
JWT_SECRET="xac_crm_secret_key_2026_revival_fitness"
JWT_ALGORITHM="HS256"
JWT_EXPIRATION_HOURS=24

# CORS - Allow origins
CORS_ORIGINS="*"

# WhatsApp Service (Baileys) - Running on always-on laptop
# Development: http://localhost:3001
# Production: http://your-laptop-public-ip:3001 or use ngrok tunnel
WHATSAPP_SERVICE_URL="http://localhost:3001"

# OpenAI API (if needed)
# OPENAI_KEY=sk-...