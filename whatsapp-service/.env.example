# WhatsApp Service Environment Variables
# This is for the separate laptop running Baileys

# MongoDB - SAME as backend!
MONGO_URL="mongodb+srv://username:password@cluster-name.mongodb.net/xac_crm_db"
DB_NAME="xac_crm_db"

# Backend URL - For reporting status and notifications
# Development: http://localhost:8001
# Production: https://your-backend.railway.app
BACKEND_URL="http://localhost:8001/api"

# Server Configuration
PORT=3001
LOG_LEVEL="info"

# Optional: Baileys specific settings
SESSION_DATA_PATH="./sessions"
